generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Use DATABASE_URL (pooled) and DIRECT_URL (direct) - works with Supabase, Neon, etc.
  // For Vercel+Neon: set DATABASE_URL and DIRECT_URL in env (or use Neon_data_* if preferred)
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?    // Image for mega-menu / category display
  type        String     // 'chariots' | 'pieces' - distinguishes main product categories
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  order       Int        @default(0)
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
  @@index([slug])
  @@index([type])
  @@index([type, parentId])
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  type        String    @default("produit") // 'produit' to distinguish from services
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  image       String?   // Single image or pipe-separated URLs (url1|url2|url3) for gallery
  features    String?
  order       Int       @default(0)
  sold        Boolean   @default(false) // For chariots: marks if the product is sold
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([type])
  @@index([sold])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  image       String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  category    String   // 'maintenance', 'reconditionnement', 'location'
  image       String?
  features    String?  // JSON string or pipe-separated
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RentalRequest {
  id             String   @id @default(cuid())
  chariot_type   String   // Category slug or name (pre-filled from selection)
  motorisation   String   // electrique | thermique
  capacite_kg    Int?
  hauteur_m     Float?
  ville         String?
  duree_location String?  // 1 semaine, 1 mois, 3 mois, 6 mois, 1 an, etc.
  type_roues    String?  // coussin, pneumatique, etc.
  type_mat      String?  // rétractable, frontal, etc.
  notes         String?
  client_name   String
  client_phone   String
  status        String   @default("new") // new | in_progress | quoted | closed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model DevisFormField {
  id         String   @id @default(cuid())
  key        String   // Unique field key (e.g. chariotType, heures)
  label      String
  type       String   // text | number | select | textarea
  required   Boolean  @default(false)
  sortOrder  Int      @default(0)
  showFor    String?  // 'all' | 'chariots-location' | 'chariots-occasion' - null = all
  placeholder String?
  options    Json?    // For select: [{ value, label }]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([key])
  @@index([sortOrder])
}

model QuoteRequest {
  id         String   @id @default(cuid())
  name       String
  email      String
  company    String?
  phone      String?
  message    String
  product    String?  // Product name from product page
  chariotType String? // Kept for backward compat
  heures     String?
  capacite   String?
  customData Json?    // Dynamic fields from admin config: { [key]: value }
  status     String   @default("new") // new | in_progress | quoted | closed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// MegaMenuPanel: image + text + CTA for mega menu Produits (occasion, transpalette, etc.)
model MegaMenuPanel {
  id        String   @id @default(cuid())
  key       String   @unique // chariots_occasion | nacelle_occasion | transpalette_manuel
  imageSrc  String
  imageAlt  String
  title     String
  body      String   @db.Text
  ctaLabel  String
  ctaHref   String
  updatedAt DateTime @updatedAt
}